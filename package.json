{
  "name": "prompt-enhancer",
  "version": "1.0.0",
  "description": "A Windows desktop app that enhances text using Gemini AI",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && npm run copy-static",
    "copy-static": "node -e \"const fs=require('fs');const p=require('path');['index.html','styles.css','prompt-dialog.html','prompt-dialog.js'].forEach(f=>fs.copyFileSync(p.join('src/renderer',f),p.join('dist/renderer',f)))\"",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "package": "npm run build && electron-builder --win --x64",
    "package:dir": "npm run build && electron-builder --win --x64 --dir"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.promptenhancer.app",
    "productName": "Prompt Enhancer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "PromptEnhancer-Portable.exe"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  }
}